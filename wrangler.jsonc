{
  "$schema": "node_modules/wrangler/config-schema.json",
  // Same Cloudflare Worker name as the live site so deploys bind to health.emailmenow.com
  "name": "health",
  "main": "src/worker/index.ts",
  "compatibility_date": "2026-07-20",
  "compatibility_flags": ["nodejs_compat"],
  "keep_vars": true,
  "routes": [
    {
      "pattern": "health.emailmenow.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    // Ensure advice/checkout APIs hit the Worker before static assets
    "run_worker_first": ["/v1/*"]
  },
  "kv_namespaces": [
    {
      "binding": "SESSIONS",
      "id": "4f0ed32c04ea42f4aa4da4ded9cab9f0",
      "preview_id": "5cceff5a53bf4ec792ae43d66b171ade"
    }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 0.1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 0.1,
      "persist": true,
      "invocation_logs": true
    }
  },
  // Secrets: wrangler secret put STRIPE_SECRET_KEY | STRIPE_WEBHOOK_SECRET | OPENAI_API_KEY
  "vars": {
    "APP_NAME": "VitalGauge",
    "APP_URL": "https://health.emailmenow.com",
    // Amazon Associates Store ID / tracking ID
    "AMAZON_ASSOCIATE_TAG": "lose1230c-20",
    // Create a Stripe Product + recurring Price, then paste the price id here (or dashboard var)
    "STRIPE_PRICE_PLUS": "price_REPLACE_ME",
    "STRIPE_PUBLISHABLE_KEY": "pk_test_REPLACE_ME"
  }
}
