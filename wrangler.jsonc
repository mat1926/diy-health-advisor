{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "diy-health-advisor",
  "main": "src/worker/index.ts",
  "compatibility_date": "2026-07-20",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "kv_namespaces": [
    {
      "binding": "SESSIONS",
      "id": "00000000000000000000000000000000",
      "preview_id": "00000000000000000000000000000000"
    }
  ],
  // Set secrets with: wrangler secret put STRIPE_SECRET_KEY | STRIPE_WEBHOOK_SECRET | OPENAI_API_KEY
  "vars": {
    "APP_NAME": "VitalGauge",
    "APP_URL": "http://localhost:8787",
    // Create a Stripe Product + recurring Price, then paste the price id here
    "STRIPE_PRICE_PLUS": "price_REPLACE_ME",
    "STRIPE_PUBLISHABLE_KEY": "pk_test_REPLACE_ME"
  }
}
